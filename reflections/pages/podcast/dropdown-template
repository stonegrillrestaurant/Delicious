<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Reflections Topic Dropdown Sample</title>

  <style>
    body{
      margin:0;
      font-family:Georgia, "Times New Roman", serif;
      background:#f7f2ec;
      color:#2c231e;
    }

    .header{
      background:#1f1815;
      color:#f3e4d5;
      padding:20px;
    }

    .wrap{
      max-width:1100px;
      margin:0 auto;
    }

    h1{
      margin:0 0 10px 0;
      font-size:1.8rem;
    }

    .manual-links{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
      margin:16px 0;
    }

    .manual-links a{
      display:inline-block;
      padding:8px 14px;
      border-radius:999px;
      text-decoration:none;
      background:#2b241f;
      color:#fff;
      border:1px solid rgba(255,255,255,.18);
    }

    .manual-links a:hover{
      background:#ff6b3d;
      color:#1f1815;
      border-color:#ff6b3d;
    }

    .dropdown-row{
      display:flex;
      flex-wrap:wrap;
      gap:12px;
      margin-top:14px;
    }

    .dropdown-box{
      display:flex;
      flex-direction:column;
      gap:6px;
    }

    label{
      font-size:.9rem;
      color:#f3e4d5;
    }

    select{
      min-width:260px;
      padding:10px 12px;
      border-radius:10px;
      border:1px solid rgba(0,0,0,.15);
      font-size:.95rem;
      font-family:inherit;
    }

    .content{
      max-width:1100px;
      margin:0 auto;
      padding:28px 20px;
    }

    .card{
      background:#fff;
      border:1px solid rgba(0,0,0,.08);
      border-radius:18px;
      padding:22px;
      box-shadow:0 10px 30px rgba(0,0,0,.05);
    }
  </style>
</head>
<body>

  <header class="header">
    <div class="wrap">
      <h1>Solitude Reflections</h1>

      <nav class="manual-links">
        <a href="/reflections/index.html">Reflections Home</a>
        <a href="/reflections/pages/the-paradox-of-god/read.html">The Paradox of God</a>
        <a href="/reflections/pages/moral-choice/read.html">Moral Choice</a>
        <a href="/reflections/pages/the-lost-language-of-metaphor/read.html">The Lost Language of Metaphor</a>
      </nav>

      <div class="dropdown-row">
        <div class="dropdown-box">
          <label for="spiritualityDropdown">Spirituality</label>
          <select id="spiritualityDropdown">
            <option value="">Choose a reflection</option>
          </select>
        </div>

        <div class="dropdown-box">
          <label for="moralityDropdown">Morality</label>
          <select id="moralityDropdown">
            <option value="">Choose a reflection</option>
          </select>
        </div>
      </div>
    </div>
  </header>

  <main class="content">
    <section class="card">
      <h2>Topic Navigation Sample</h2>
      <p>This example shows manual links plus two dropdowns grouped by topic.</p>
    </section>
  </main>

  <script>
    window.REFLECTION_LINKS = [
      {title:"Divine Hiddenness", url:"/reflections/pages/divine-hiddeness/read.html"},
      {title:"The Subconscious Mind", url:"/reflections/pages/subconsciousmind/read.html"},
      {title:"The God We Created", url:"/reflections/pages/the-god-we-created/read.html"},
      {title:"The Paradox of God", url:"/reflections/pages/the-paradox-of-god/read.html"},
      {title:"The Journey To Self", url:"/reflections/pages/the-journey-to-self/read.html"},
      {title:"The Prayer", url:"/reflections/pages/the-inner-listener/read.html"},
      {title:"Transcendence", url:"/reflections/pages/transcendence/read.html"},
      {title:"The Madness of Faith", url:"/reflections/pages/the-madness-of-fath/read.html"},
      {title:"The Lost Language of Metaphor", url:"/reflections/pages/the-lost-language-of-metaphor/read.html"},
      {title:"Moral Choice", url:"/reflections/pages/moral-choice/read.html"},
      {title:"Belief and Goodness", url:"/reflections/pages/belief/read.html"},
      {title:"Seeking Assurance is Labeled a Sinner", url:"/reflections/pages/question-label-sinner/read.html"},
      {title:"The Initial Premise", url:"/reflections/pages/initial-premise/read.html"},
      {title:"The Deity", url:"/reflections/pages/diety/read.html"},
      {title:"Silent Influence", url:"/reflections/pages/silent-influence/read.html"},
      {title:"Oneness & Duality", url:"/reflections/pages/oneness-duality/read.html"},
      {title:"The Mirror of Worship", url:"/reflections/pages/mirror-of-worship/read.html"},
      {title:"Good and Evil", url:"/reflections/pages/godevil/read.html"},
      {title:"The Kingdom Within", url:"/reflections/pages/kingdom_within/read.html"},
      {title:"Feeding the Soul", url:"/reflections/pages/soul/read.html"}
    ];

    const spiritualityLinks = [
      { title: "Divine Hiddenness", url: "/reflections/pages/divine-hiddeness/read.html" },
      { title: "The Paradox of God", url: "/reflections/pages/the-paradox-of-god/read.html" },
      { title: "The Kingdom Within", url: "/reflections/pages/kingdom_within/read.html" },
      { title: "Feeding the Soul", url: "/reflections/pages/soul/read.html" }
    ];

    const moralityLinks = [
      { title: "Moral Choice", url: "/reflections/pages/moral-choice/read.html" },
      { title: "Belief and Goodness", url: "/reflections/pages/belief/read.html" },
      { title: "Good and Evil", url: "/reflections/pages/godevil/read.html" },
      { title: "Seeking Assurance is Labeled a Sinner", url: "/reflections/pages/question-label-sinner/read.html" }
    ];

    function fillDropdown(dropdownId, links) {
      const dropdown = document.getElementById(dropdownId);
      if (!dropdown) return;

      links.forEach(function(item) {
        const option = document.createElement("option");
        option.value = item.url;
        option.textContent = item.title;
        dropdown.appendChild(option);
      });

      dropdown.addEventListener("change", function() {
        if (this.value) {
          window.location.href = this.value;
        }
      });
    }

    fillDropdown("spiritualityDropdown", spiritualityLinks);
    fillDropdown("moralityDropdown", moralityLinks);
  </script>

</body>
</html>